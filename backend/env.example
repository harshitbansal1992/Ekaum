# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Port
PORT=3000

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# For Supabase: Check your project settings for the connection string
# For Neon: Check your project dashboard for the connection string
# For Railway: Use the DATABASE_URL provided by Railway
DATABASE_URL=postgresql://user:password@localhost:5432/bslnd_db

# JWT Secret Key (Change this to a random string in production!)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Razorpay Payment Gateway (Test credentials for development)
RAZORPAY_KEY_ID=rzp_test_STczlMNUcWRhnZ
RAZORPAY_KEY_SECRET=1iKp0T2zklGHZYauUezZiMO5
# Optional: For webhook signature verification
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Instamojo (legacy, deprecated)
INSTAMOJO_API_KEY=your-instamojo-api-key
INSTAMOJO_AUTH_TOKEN=your-instamojo-auth-token

# Hindu Calendar / Today's Panchang (FREE)
# Sign up at https://kaalchakra.dev/signup for a free API key.
# Shows Tithi, Nakshatra, Vara, Paksha on home screen.
# KAALCHAKRA_API_KEY=your-free-api-key

# Environment
NODE_ENV=development

# === Production (set these when deploying) ===
# PORT=8080
# CORS_ORIGIN=https://your-domain.com
# JWT_EXPIRES_IN=24h
# DB_POOL_MIN=10
# DB_POOL_MAX=30
# REQUEST_LOGGING=false
# RATE_LIMIT_ENABLED=true (via NODE_ENV=production)
# REDIS_URL=redis://localhost:6379  # Optional: for future Redis caching
