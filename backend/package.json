{
  "name": "bslnd-backend",
  "version": "1.0.0",
  "description": "RESTful Backend API for BSLND Flutter mobile application with authentication, payments, and content management",
  "main": "server.js",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "test": "cross-env NODE_ENV=test node server.js",
    "test:watch": "cross-env NODE_ENV=test nodemon server.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"server.js\"",
    "mode:info": "node -e \"const { config, getModeConfig } = require('./src/config'); console.log(JSON.stringify(getModeConfig(), null, 2));\"",
    "seed:paath-forms": "node scripts/seed-dummy-paath-forms.js",
    "seed:full": "node scripts/seed-full-test-data.js",
    "migrate": "node scripts/run-migrations.js",
    "schema:init": "node scripts/init-schema.js"
  },
  "keywords": [
    "bslnd",
    "api",
    "nodejs",
    "express",
    "postgresql",
    "rest-api",
    "authentication",
    "jwt"
  ],
  "author": "BSLND Team",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bslnd-backend"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0"
  }
}
