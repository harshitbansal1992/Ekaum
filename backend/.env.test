# BSLND Backend - Test Mode Environment Variables
# ================================================
# This file contains configuration for running tests
# Use separate test database to avoid affecting production/dev data

# Server Configuration
PORT=3001
NODE_ENV=test
LOG_LEVEL=warn

# PostgreSQL Database URL (Test - Use separate test database)
# Example: postgresql://username:password@localhost:5432/bslnd_test
DATABASE_URL=postgres://username:password@127.0.0.1:5432/test_database?sslmode=disable

# Database Pool Configuration (Minimal for testing)
DB_POOL_MIN=1
DB_POOL_MAX=5

# JWT Configuration
# Shorter expiry for test environment
JWT_SECRET=test-secret-key-for-testing-only
JWT_EXPIRES_IN=1h

# CORS Configuration (Allow all origins for testing)
CORS_ORIGIN=*

# Request Logging (Disabled to keep test output clean)
REQUEST_LOGGING=false

# Instamojo Payment Gateway (Mock for testing)
INSTAMOJO_API_KEY=test-api-key-mock
INSTAMOJO_AUTH_TOKEN=test-auth-token-mock

# Feature Flags (Test-specific)
# Mock payments enabled to avoid actual charges during testing
CACHING_ENABLED=false
RATE_LIMIT_ENABLED=false
MOCK_PAYMENTS=true
ERROR_TRACKING=false

